        "%%writefile fib_recursive.c\n",
        "#include <stdio.h>\n",
        "#include <time.h>\n",
        "\n",
        "// Recursive Fibonacci function\n",
        "long long fib(int n) {\n",
        "    if (n <= 1)\n",
        "        return n;\n",
        "    return fib(n - 1) + fib(n - 2);\n",
        "}\n",
