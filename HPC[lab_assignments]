        "    clock_t start, end;\n",
        "\n",
        "    start = clock();\n",
        "    long long result = fib(n);\n",
        "    end = clock();\n",
        "\n",
        "    double time_taken = (double)(end - start) / CLOCKS_PER_SEC;\n",
        "\n",
        "    printf(\"Fibonacci(%d) = %lld\\n\", n, result);\n",
        "    printf(\"Execution Time = %.6f seconds\\n\", time_taken);\n",
        "\n",
        "    return 0;\n",
        "}"
